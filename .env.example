# Promptish webdev harness — copy to .env and fill in.

# Port the harness UI listens on (browser opens http://localhost:PORT/).
PORT=7878

# Path to the static site this harness edits. Single-site v1.
# Default scaffold (./sites/example) is fine for first-run.
# Point this at your real site (absolute path recommended) to edit it.
SITE_PATH=./sites/example

# Path to the SQLite chat-history DB. Created automatically on first run.
DB_PATH=./harness.db

# Anthropic credentials — provide ONE of these, not both:
#
# (a) Claude Code subscription users: leave ANTHROPIC_API_KEY blank.
#     Run `claude /login` once on this machine. The harness picks up your
#     Claude Code session automatically. No per-token billing.
#
# (b) Anthropic Console users: set ANTHROPIC_API_KEY below.
#     Get one at https://console.anthropic.com/. Bills your Anthropic account
#     per token (typically a few cents per chat for this use case).
#
ANTHROPIC_API_KEY=

# Model the agent runs as. Defaults to claude-sonnet-4-6.
MODEL=claude-sonnet-4-6
